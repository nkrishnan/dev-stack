#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${DEV_STACK_HOME:-}" ]]; then
  STACK_DIR="$DEV_STACK_HOME"
else
  SCRIPT_PATH="${BASH_SOURCE[0]}"
  while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
  done
  STACK_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")/.." && pwd)"
fi
BIN_DIR="${HOME}/.local/bin"

_install_opencode() {
  if command -v opencode &>/dev/null; then return; fi
  echo "Installing opencode..."
  curl -fsSL https://opencode.ai/install | bash
}

_install_mise() {
  if command -v mise &>/dev/null; then return; fi
  echo "Installing mise..."
  curl -fsSL https://mise.run | bash
}

_install_uv() {
  if command -v uv &>/dev/null; then return; fi
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | bash
}

_install_specify_cli() {
  if command -v specify &>/dev/null; then return; fi
  echo "Installing specify-cli (spec-kit)..."
  local version
  version="$(curl -fsSL https://api.github.com/repos/github/spec-kit/releases/latest | grep '"tag_name"' | cut -d'"' -f4)"
  uv tool install specify-cli --from "git+https://github.com/github/spec-kit.git@${version}"
}

_install_openspec() {
  if command -v openspec &>/dev/null && openspec --version &>/dev/null; then return; fi

  if command -v npm &>/dev/null; then
    echo "Installing openspec..."
    npm install -g @fission-ai/openspec@latest
    return
  fi

  if command -v mise &>/dev/null; then
    echo "Installing openspec via mise (node@20)..."
    mise x node@20 -- npm install -g @fission-ai/openspec@latest --prefix "$HOME/.local"
    return
  fi

  echo "Skipping openspec install: neither npm nor mise is available on PATH."
}

_run_openspec() {
  if command -v openspec &>/dev/null && command -v node &>/dev/null; then
    openspec "$@"
    return
  fi

  if command -v mise &>/dev/null; then
    mise x node@20 -- openspec "$@"
    return
  fi

  return 127
}

_run_node() {
  if command -v node &>/dev/null; then
    node "$@"
    return
  fi

  if command -v mise &>/dev/null; then
    mise x node@20 -- node "$@"
    return
  fi

  return 127
}

_configure_openspec_extended_profile() {
  local config_path
  if ! config_path="$(_run_openspec config path 2>/dev/null)"; then
    return 1
  fi

  mkdir -p "$(dirname "$config_path")"
  _run_node - "$config_path" <<'EOF'
const fs = require('fs');
const configPath = process.argv[2];
const workflows = [
  'propose',
  'explore',
  'new',
  'continue',
  'apply',
  'ff',
  'sync',
  'archive',
  'bulk-archive',
  'verify',
  'onboard',
];

let config = {};
if (fs.existsSync(configPath)) {
  try {
    config = JSON.parse(fs.readFileSync(configPath, 'utf8'));
  } catch {
    config = {};
  }
}

config.profile = 'custom';
if (!config.delivery) {
  config.delivery = 'both';
}
config.workflows = workflows;

fs.writeFileSync(configPath, JSON.stringify(config, null, 2) + '\n', 'utf8');
EOF
}

_init_openspec_for_opencode() {
  # Non-interactive setup for OpenCode installs OpenSpec skills + opsx commands
  # under .opencode/.
  if ! _run_openspec --version >/dev/null 2>&1; then
    echo "Skipping openspec project init: openspec runtime is not available."
    return
  fi

  if ! _configure_openspec_extended_profile >/dev/null 2>&1; then
    echo "Warning: could not configure openspec extended workflow profile."
  fi

  if ! _run_openspec init --tools opencode --profile custom >/dev/null 2>&1; then
    echo "Warning: openspec init for opencode failed; run 'openspec init --tools opencode --profile custom' manually."
  fi
}

_ensure_path_dir_on_path() {
  local dir="$1"
  local snippet="export PATH=\"$dir:\$PATH\""
  local added=0
  for profile in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [[ -f "$profile" ]]; then
      grep -qF "$dir" "$profile" || { echo "$snippet" >> "$profile"; added=1; }
    fi
  done
  # No profile existed yet — create .bashrc so the next shell has it
  if [[ $added -eq 0 && ! -f "$HOME/.bashrc" ]]; then
    echo "$snippet" > "$HOME/.bashrc"
  fi
  # Also apply to the current session so tools installed next are findable
  case ":$PATH:" in
    *":$dir:"*) ;;
    *) export PATH="$dir:$PATH" ;;
  esac
}

_ensure_bin_on_path() {
  _ensure_path_dir_on_path "$HOME/.local/bin"
}

install_stack() {
  mkdir -p "$BIN_DIR"
  ln -sfn "$STACK_DIR/bin/dev-stack" "$BIN_DIR/dev-stack"
  _ensure_bin_on_path

  if [[ "${DEV_STACK_SKIP_TOOLS:-}" != "1" ]]; then
    _install_opencode
    _ensure_path_dir_on_path "$HOME/.opencode/bin"
    _install_mise
    _install_uv
    _install_specify_cli
    _install_openspec
  fi

  if [[ -z "${OPENROUTER_API_KEY:-}" ]]; then
    echo "Reminder: set OPENROUTER_API_KEY in your environment or Codespaces secrets."
  fi
}

init_project() {
  cp -n "$STACK_DIR/templates/project/opencode.json" ./opencode.json
  mkdir -p .cursor/rules
  cp -n "$STACK_DIR/templates/project/.cursor/rules/dev-stack.md" .cursor/rules/dev-stack.md
  _init_openspec_for_opencode
  touch .git/info/exclude
  grep -qxF ".env.local" .git/info/exclude || echo ".env.local" >> .git/info/exclude
  grep -qxF ".opencode-auth.json" .git/info/exclude || echo ".opencode-auth.json" >> .git/info/exclude
  echo "Dev stack initialized."
}

bootstrap() {
  if ! git rev-parse --git-dir &>/dev/null; then
    echo "Error: not inside a git repository. Run from a project root." >&2
    return 1
  fi

  install_stack
  init_project
}

case "${1:-}" in
  install) install_stack ;;
  init) init_project ;;
  bootstrap) bootstrap ;;
  *) echo "Usage: dev-stack install | init | bootstrap"; exit 1 ;;
esac
